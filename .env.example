# Core
DATABASE_URL="file:./dev.db"
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
APP_ENV="development"
CRON_SECRET="change-me-for-cron-routes"
ADMIN_LOCAL_PASSWORD="change-me-local-admin-password"
ADMIN_EMAILS="omnistat@yandex.ru"
JWT_SECRET="change-me-please-32-characters-minimum"
UPLOAD_DIR="./uploads"

# LLM provider: openai | gemini | local
LLM_PROVIDER="local"
OPENAI_API_KEY=""
OPENAI_MODEL="gpt-5.4"
GEMINI_API_KEY=""
GEMINI_MODEL="gemini-3.1-flash-lite"
OPENROUTER_API_KEY=""
OPENROUTER_MODEL="google/gemini-2.0-flash-exp:free"
GROQ_API_KEY=""
GROQ_MODEL="llama-3.3-70b-versatile"

# Bibliometrics / harvesting
SCOPUS_API_KEY=""
SCOPUS_INST_TOKEN=""
SCOPUS_MAX_RESULTS_PER_AUTHOR="200"
WOS_API_KEY=""
CLARIVATE_WOS_API_KEY=""
ELIBRARY_COOKIE=""
ELIBRARY_PROXY_URL=""
ELIBRARY_USER_AGENT="Mozilla/5.0 smu-fnisc-platform/0.1"
OPENALEX_MAILTO="omnistat@yandex.ru"

# Media monitoring
MEDIA_QUERY_LANGS="ru,en"
MEDIA_AUTO_PUBLISH_THRESHOLD="0.75"
MEDIA_MAX_RESULTS_PER_MEMBER="30"
MEDIA_REQUEST_TIMEOUT_MS="8000"
MEDIA_RETRY_COUNT="1"
MEDIA_POLITE_DELAY_MS="5500"
MEDIA_ENABLE_GOOGLE_NEWS="false"
MEDIA_ENABLE_BING_SEARCH="true"
MEDIA_BING_MAX_QUERIES_PER_MEMBER="6"
MEDIA_BING_MAX_ITEMS_PER_QUERY="10"
GDELT_TIMESPAN="3m"
GDELT_MAX_RECORDS_PER_QUERY="75"
GDELT_REQUEST_TIMEOUT_MS="20000"
GDELT_REQUEST_DELAY_MS="6500"
